{
  "name": "moveapp",
  "private": true,
  "version": "0.1.0",
  "description": "App de transporte por aplicativo (passageiro + motorista) - monorepo",
  "scripts": {
    "backend:dev": "pnpm --filter backend start:dev",
    "backend:build": "pnpm --filter backend build",
    "mobile:start": "pnpm --filter mobile start",
    "admin:start": "pnpm --filter admin dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:migrate": "pnpm --filter backend prisma migrate dev",
    "prisma:generate": "pnpm --filter backend prisma generate",
    "prisma:studio": "pnpm --filter backend prisma studio"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
